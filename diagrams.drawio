        <mxCell id="nslGAu7CYD1ucYqMFyyi-50" value="&lt;h1 data-start=&quot;1511&quot; data-end=&quot;1550&quot;&gt;Architecture&lt;/h1&gt;&lt;p data-start=&quot;1552&quot; data-end=&quot;1609&quot;&gt;&lt;/p&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
