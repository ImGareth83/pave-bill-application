lt;div class=&quot;cm-scroller&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot; style=&quot;forced-color-adjust: none;&quot;&gt;{&lt;br style=&quot;forced-color-adjust: none;&quot;&gt;&quot;billId&quot;:&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;ͼr&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&quot;bill_001&quot;&lt;/span&gt;,&lt;br style=&quot;forced-color-adjust: none;&quot;&gt;&quot;status&quot;:&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;ͼr&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&quot;CLOSED&quot;&lt;/span&gt;,&lt;br style=&quot;forced-color-adjust: none;&quot;&gt;&quot;totalAmount&quot;:&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;ͼr&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&quot;220.50&quot;&lt;/span&gt;&lt;br style=&quot;forced-color-adjust: none;&quot;&gt;}&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&lt;b&gt;4. Complete Bill&lt;/b&gt;&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&lt;b&gt;POST &lt;/b&gt;/bills/{billId}/complete&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot; style=&quot;forced-color-adjust: none;&quot;&gt;Response&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; {&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;billId&quot;: &quot;019ccc84-2441-735e-b12a-ff1a51b9c67f&quot;,&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;status&quot;: &quot;COMPLETED&quot;,&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;totalAmount&quot;: &quot;0.00&quot;,&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;completedAt&quot;: &quot;2026-03-08T10:15:20.035Z&quot;&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; }&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; {&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;code&quot;: &quot;invalid_argument&quot;,&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;message&quot;: &quot;bill completion is managed by the workflow and happens at period end or after close&quot;,&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;details&quot;: {&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;code&quot;: &quot;BillCompletionManagedByWorkflow&quot;&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot; style=&quot;forced-color-adjust: none;&quot;&gt;&lt;br style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
