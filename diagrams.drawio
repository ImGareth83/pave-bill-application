        <mxCell id="AnzKkl3qhIyDMU6pidJ5-39" value="&lt;p class=&quot;p2&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;&lt;b&gt;Use of Artificial Intelligence&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;The system is made of:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s2&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- backend API&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Temporal workflow orchestration&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Temporal worker&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Postgres&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Encore Cloud&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- EC2&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s2&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;None of that uses AI to make business decisions or process bills.&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s2&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Where AI was used here is in the development process:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s2&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- reviewing source code&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- refactoring architecture&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- diagnosing Encore/Temporal/EC2 issues&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- generating and editing code/docs/workflows&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- helping design the deployment split&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;So:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s2&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- &lt;b&gt;runtime product behavior&lt;/b&gt;: no AI&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s2&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- &lt;b&gt;engineering/build/debug workflow&lt;/b&gt;: AI-assisted development&lt;/span&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="1200" width="730" height="650" as="geometry" />
        </mxCell>
        <mxCell id="AnzKkl3qhIyDMU6pidJ5-40" value="one bill one workflow concept" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1720" y="380" width="170" height="100" as="geometry" />
        </mxCell>
        <mxCell id="AnzKkl3qhIyDMU6pidJ5-41" value="" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="AnzKkl3qhIyDMU6pidJ5-40" target="nslGAu7CYD1ucYqMFyyi-28">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="2058" y="410" as="sourcePoint" />
            <mxPoint x="2110" y="296" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <UserObject label="&lt;span class=&quot;s1&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;&lt;b&gt;Tradeoffs for Cross Service Interactions&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;1. Split orchestration from persistence&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;The workflow code in &lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;bill-period.ts&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt; does orchestration only, while backend in &lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;backend.ts&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt; owns all DB writes.&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: clean ownership, no direct DB access from worker/workflow&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: every workflow mutation becomes a network hop back into backend&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;2. Use Temporal updates instead of direct mutation handlers&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Public mutation APIs do not write state directly. They send workflow updates through Temporal.&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: bill lifecycle remains coordinated by one workflow execution&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: simple writes become dependent on Temporal + worker availability&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;3. External worker calling backend over HTTP&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Activities in &lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;bill-activities.ts&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt; call backend &lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;/workflow/*&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt; endpoints over HTTPS.&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: worker stays stateless with respect to DB&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: internal persistence endpoints must be publicly reachable&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;4. Backend as idempotency authority&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Backend handles idempotency for public APIs and worker persistence calls.&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: durable replay safety is centralised&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: dedupe is spread across backend idempotency and workflow in-flight request tracking&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;5. Backend on Encore, worker on EC2&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;The current deployment model separates the API runtime from the worker runtime.&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: each runtime fits its job better&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: operational complexity increases because deployment, config, and monitoring are split&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;6. Public &lt;/b&gt;&lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;/workflow/*&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt;&lt;b&gt; persistence endpoints&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;The code explicitly exposes worker-facing endpoints in &lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;backend.ts&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt;.&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: simple connectivity for EC2 worker&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: weaker boundary; external callers can reach those endpoints too&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;7. Workflow-driven completion&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Bill completion is managed by the workflow, not by a direct public command.&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: period-end automation and lifecycle sequencing stay consistent&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: API semantics are less direct, e.g. &lt;/span&gt;&lt;span class=&quot;s2&quot;&gt;POST /bills/:billId/complete&lt;/span&gt;&lt;span class=&quot;s1&quot;&gt; is now confirmation, not command&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;b&gt;8. Single long-lived worker&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;The architecture assumes one external worker process polling Temporal.&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;Tradeoff:&lt;/span&gt;&lt;p class=&quot;p2&quot;&gt;&lt;span class=&quot;s1&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Pro: simple to operate initially&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- Con: resilience is limited until you add more worker instances&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;So the core architectural tradeoff is:&lt;br&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- strong separation of concerns and correct Temporal execution model&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;s1&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp; &lt;/span&gt;- in exchange for more cross-service coordination, more public surface area, and more operational moving parts&lt;/span&gt;" id="AnzKkl3qhIyDMU6pidJ5-42">
          <mxCell style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
            <mxGeometry x="2520" y="30" width="560" height="1080" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
