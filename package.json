{
  "name": "pave-bill-application",
  "private": true,
  "version": "0.0.1",
  "description": "Monorepo for the Encore billing backend and Temporal workflow worker",
  "license": "MPL-2.0",
  "type": "module",
  "scripts": {
    "test": "npm run test:backend && npm run test:workflow",
    "test:backend": "npm --prefix backend test",
    "test:workflow": "npm --prefix workflow test",
    "typecheck": "npm run typecheck:backend && npm run typecheck:workflow",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "typecheck:workflow": "npm --prefix workflow run typecheck",
    "worker": "npm --prefix workflow run worker"
  },
  "dependencies": {
    "@temporalio/activity": "^1.11.5",
    "@temporalio/client": "^1.11.5",
    "@temporalio/common": "^1.11.5",
    "@temporalio/worker": "^1.11.5",
    "@temporalio/workflow": "^1.11.5",
    "encore.dev": "^1.54.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.7",
    "tsx": "^4.19.2",
    "typescript": "^5.2.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.13.0"
  }
}
